# MCP 서버용 환경 변수 예시
# 이 파일을 복사하여 .env.mcp 로 저장한 뒤, 실제 키/토큰 값을 채워 넣으세요.
# .env.mcp 는 Git에 포함되지 않습니다.

# Context7 - 최신 코드 문서 조회 (무료 1000회/월, context7.com에서 발급)
CONTEXT7_API_KEY=여기에_Context7_API_키_입력

# GitHub - 저장소/이슈/PR 조회·생성 (GitHub Settings > Developer settings > Personal access tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Supabase - DB·인증 연동 (Supabase 대시보드에서 발급)
SUPABASE_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel - 배포·프로젝트 관리 (Vercel 대시보드 Account > Tokens)
VERCEL_TOKEN=vercel_xxxxxxxxxxxxxxxxxxxx

# Sentry - 에러/이슈 조회 (Sentry Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
