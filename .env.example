# =============================================================================
# 필수: 사용할 LLM 프로바이더 (claude | gemini | groq 중 하나)
# 아래 해당 블록에서 API 키와 모델만 설정하면 됨
# =============================================================================
LLM_PROVIDER=gemini

# --- Anthropic / Claude (LLM_PROVIDER=claude 일 때) ---
# Anthropic API 키 (https://console.anthropic.com 에서 발급)
# ANTHROPIC_API_KEY=
# 사용할 Claude 모델명 (기본: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Gemini (LLM_PROVIDER=gemini 일 때) ---
# Google AI Studio API 키 (https://aistudio.google.com/apikey 에서 발급)
# GEMINI_API_KEY=
# 사용할 Gemini 모델명 (예: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Groq (LLM_PROVIDER=groq 일 때) ---
# Groq API 키 (https://console.groq.com 에서 발급, 무료 한도 넉넉)
# GROQ_API_KEY=
# 사용할 Groq 모델명 (예: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
# Groq 전용: 요청(user) 메시지 최대 문자 수. 413 에러 방지 (0=제한 없음, 10000~12000 권장)
# GROQ_MAX_USER_MESSAGE_CHARS=10000

# --- 공통 (모든 프로바이더 적용) ---
# 로그 레벨: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
# LLM 응답 최대 토큰 수. 클수록 더 긴·상세한 응답 (8192=상세, 16384=더 긴 응답)
# LLM_MAX_TOKENS=8192
# JSON/형식 준수 유도. 0.2~0.5 권장 (낮을수록 형식 준수, 제안서 품질 개선)
# LLM_TEMPERATURE=0.4
# API 일시 오류(429 등) 시 재시도 횟수 (1~10)
# LLM_RETRY_COUNT=3
# JSON 추출 실패 시 재시도 횟수 (1~5). 2=1차 실패 시 1회 재시도
# LLM_JSON_RETRY_COUNT=2
# 재시도 시 대기 시간(초) 기준값. 지수 백오프 적용
# LLM_RETRY_BASE_DELAY=5
# API 호출 직후 대기(초). 429 방지 (0=대기 없음, 무료 한도 시 5~10 권장)
# LLM_DELAY_SECONDS=8

# =============================================================================
# v4.0 고도화 옵션 (기본값으로도 잘 동작함 — 필요 시만 수정)
# =============================================================================

# --- RFP Chunking (긴 RFP 문서 처리 품질 향상) ---
# RFP 청킹 활성화. 평가기준·요구사항 섹션을 우선 포함해 컨텍스트 품질 향상
# ENABLE_RFP_CHUNKING=true
# 청킹 후 최대 문자 수 (기본 40000 = 약 2만 한글 자)
# RFP_CHUNK_MAX_CHARS=40000

# --- 품질 스코어링 (슬라이드 자동 채점) ---
# 슬라이드 품질 자동 채점 활성화 (Action Title·구체성·플레이스홀더 검사)
# ENABLE_QUALITY_SCORING=true
# Phase 평균 품질 기준점 (0~100, 이 점수 미만 시 경고 로그)
# MIN_QUALITY_SCORE=60
# 개별 슬라이드 최소 점수 (이 점수 미만 슬라이드는 저품질 목록에 포함)
# MIN_SLIDE_QUALITY_SCORE=40

# --- Cross-Phase Context (Phase 간 내러티브 일관성) ---
# 이전 Phase 핵심 결론을 다음 Phase 프롬프트에 자동 주입
# ENABLE_CROSS_PHASE_CONTEXT=true

# --- Phase Checkpoint (생성 중간 저장 → API 실패 시 복구 가능) ---
# 각 Phase 생성 후 output/_checkpoints/ 에 JSON 저장
# ENABLE_CHECKPOINT=true

# --- Industry Stats DB (업종별 검증 통계 주입 → 수치 구체성 향상) ---
# 프롬프트에 업종별 통계 자동 주입 (marketing_pr, it_system, event 등)
# ENABLE_INDUSTRY_STATS=true
# 커스텀 통계 JSON 파일 경로 (미설정 시 내장 DB 사용)
# INDUSTRY_STATS_PATH=company_data/custom_stats.json

# --- 프롬프트 버전 관리 ---
# 버전 지정 시 config/prompts/{PROMPT_VERSION}/ 디렉토리를 우선 탐색
# PROMPT_VERSION=

# --- Action Title 자동 수정 (실험적) ---
# 생성된 슬라이드 제목이 Topic Title 패턴이면 자동으로 재생성 시도
# ENABLE_AUTO_FIX_TITLES=false

# --- Self-Refinement (초안→비평→개선, 실험적 · 토큰 2~3배 소비) ---
# ENABLE_SELF_REFINEMENT=false
