# 필수: 사용할 LLM (claude | gemini | groq) — 아래 해당 블록만 키 설정
LLM_PROVIDER=gemini

# --- Gemini (LLM_PROVIDER=gemini 일 때) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic / Claude (LLM_PROVIDER=claude 일 때) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Groq (LLM_PROVIDER=groq 일 때) ---
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MAX_USER_MESSAGE_CHARS=10000

# --- 공통 (모든 프로바이더 적용) ---
# LOG_LEVEL=INFO
# LLM_MAX_TOKENS=8192  (응답 최대 토큰. 8192=상세 응답, 16384=더 긴 응답)
# LLM_RETRY_COUNT=3
# LLM_RETRY_BASE_DELAY=5
# LLM_DELAY_SECONDS=8
