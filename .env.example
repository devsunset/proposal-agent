# 필수: 사용할 LLM (claude | gemini | groq)
LLM_PROVIDER=gemini

# 선택한 프로바이더에 맞는 키만 설정
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# 선택: 모델 오버라이드
# GEMINI_MODEL=gemini-2.5-flash-lite
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# GROQ_MODEL=llama-3.1-8b-instant

# 선택: 429/413 대응 (API 호출 간 대기·메시지 길이 제한)
# GEMINI_DELAY_SECONDS=8
# GROQ_MAX_USER_MESSAGE_CHARS=10000
# GROQ_DELAY_SECONDS=0

# 선택: 로그 레벨 (DEBUG | INFO | WARNING | ERROR)
# LOG_LEVEL=INFO

# 선택: LLM 재시도·토큰 (일시 오류/429 시 재시도)
# LLM_MAX_TOKENS=4096
# LLM_RETRY_COUNT=3
# LLM_RETRY_BASE_DELAY=5
