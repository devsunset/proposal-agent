# =============================================================================
# LLM 프로바이더 선택 (claude | gemini | groq | ollama 중 하나)
# ollama = 로컬 LLM, API 키 불필요 (ollama.md 참고)
# =============================================================================
LLM_PROVIDER=gemini


# =============================================================================
# [Claude / Anthropic] — LLM_PROVIDER=claude 일 때 사용
# 발급: https://console.anthropic.com
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# =============================================================================
# [Gemini / Google] — LLM_PROVIDER=gemini 일 때 사용
# 발급: https://aistudio.google.com/apikey
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash


# =============================================================================
# [Groq] — LLM_PROVIDER=groq 일 때 사용
# 발급: https://console.groq.com (무료 한도 넉넉)
# =============================================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# 요청(user) 메시지 최대 문자 수. 413 에러 방지 (0=제한 없음, 6000~12000 권장)
GROQ_MAX_USER_MESSAGE_CHARS=6000


# =============================================================================
# [Ollama 로컬 LLM] — LLM_PROVIDER=ollama 일 때 사용 (API 키 불필요)
# 로컬 Ollama 설치 후 ollama run <모델> 또는 서비스 실행 필요 (ollama.md 참고)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b


# =============================================================================
# 공통 LLM 옵션 — 모든 프로바이더에 적용
# =============================================================================
# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# LLM 응답 최대 토큰 수 (8192=상세, 16384=긴 응답, 모델 한도 내)
LLM_MAX_TOKENS=18684

# JSON 형식 준수 온도 (0.2~0.5 권장, 낮을수록 형식 준수)
LLM_TEMPERATURE=0.4

# API 일시 오류(429 등) 시 재시도 횟수 (1~10)
LLM_RETRY_COUNT=3

# JSON 추출 실패 시 재시도 횟수 (1~5). 2=실패 시 1회 재시도
LLM_JSON_RETRY_COUNT=2

# 재시도 시 대기 기준값(초). 지수 백오프 적용 (5 → 5초, 10초, 20초)
LLM_RETRY_BASE_DELAY=5

# API 호출 직후 대기(초). 429 방지 (0=대기 없음, 무료 한도 시 5~10 권장)
LLM_DELAY_SECONDS=5


# =============================================================================
#  고도화 옵션 — RFP 분석 품질
# =============================================================================
# RFP 청킹 활성화. 평가기준·요구사항 섹션 우선 포함 (기존 25,000자 → 40,000자)
ENABLE_RFP_CHUNKING=true

# 청킹 후 최대 문자 수 (약 2만 한글 자)
RFP_CHUNK_MAX_CHARS=40000


# =============================================================================
#  고도화 옵션 — 슬라이드 품질 스코어링
# =============================================================================
# 슬라이드 자동 채점 활성화 (Action Title·구체성·플레이스홀더 검사)
ENABLE_QUALITY_SCORING=true

# Phase 평균 품질 기준 점수 (이 점수 미만 시 WARNING 로그 출력)
MIN_QUALITY_SCORE=60

# 개별 슬라이드 최저 기준 점수 (이 점수 미만 슬라이드는 저품질 목록에 포함)
MIN_SLIDE_QUALITY_SCORE=40


# =============================================================================
#  고도화 옵션 — Phase 간 일관성 및 저장
# =============================================================================
# Cross-Phase Context: 이전 Phase 핵심 결론을 다음 Phase 프롬프트에 자동 주입
ENABLE_CROSS_PHASE_CONTEXT=true

# Phase Checkpoint: 각 Phase 완료 후 output/_checkpoints/ 에 JSON 저장 (복구용)
ENABLE_CHECKPOINT=true


# =============================================================================
#  고도화 옵션 — 콘텐츠 보강
# =============================================================================
# 업종별 검증 통계 자동 주입 (marketing_pr, it_system, event 등)
ENABLE_INDUSTRY_STATS=true

# 커스텀 통계 JSON 경로 (미설정 시 내장 DB 사용)
# INDUSTRY_STATS_PATH=company_data/custom_stats.json


# =============================================================================
#  고도화 옵션 — 프롬프트 관리
# =============================================================================
# 프롬프트 버전 지정 시 config/prompts/{PROMPT_VERSION}/ 디렉토리 우선 탐색
# PROMPT_VERSION=


# =============================================================================
#  고도화 옵션 — 실험적 기능 (기본 off)
# =============================================================================
# Action Title 자동 수정: Topic Title 패턴 감지 시 재생성 시도
ENABLE_AUTO_FIX_TITLES=false

# Self-Refinement: Draft → Critique → Refine 사이클 (토큰 2~3배 소비)
ENABLE_SELF_REFINEMENT=false
